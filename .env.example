# Config local (NU commit-ui acest fisier ca .env.local)
# Copiaza-l in .env.local si seteaza valorile pentru mediul tau local

# Database
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=dms_dev
DB_USER=
DB_PASSWORD=
# In productie recomandat: true
DB_ENCRYPT=false
# In productie recomandat: false (seteaza true doar pentru cert self-signed intern)
DB_TRUST_CERT=true

# Active Directory
AD_URL=ldap://anre-ad-a01.intern.anre
AD_DOMAIN=intern.anre
AD_BASE_DN=DC=intern,DC=anre

# Autorizare
# Lista de useri AD (nume.prenume) care au acces la panou
DOMAIN_ADMINS=nume.prenume

# Cookie
COOKIE_SECRET=schimba_asta_cu_un_string_random_lung
# Activeaza doar daca rulezi strict in spatele unui proxy/IIS de incredere
TRUST_PROXY_AUTH_HEADERS=false

# Login rate-limit (protectie brute-force)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# App
NODE_ENV=development
HOSTNAME=0.0.0.0
PORT=3000
